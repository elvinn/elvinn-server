{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2018",
    "lib": ["ES2015", "DOM"],
    "noImplicitAny": true,
    "noEmitOnError": true,
    "removeComments": true,
    "preserveConstEnums": true,
    "outDir": "./dist",
    "rootDir": "./src/"
  },
  "include": [
    "src/**/*",
  ],
  "exclude": [
    "node_modules",
    "**/*.spec.ts",
  ]
}